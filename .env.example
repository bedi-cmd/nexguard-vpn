# ───── Database ─────
# Local dev: docker-compose up -d → use the URL below.
# Prod: swap to Neon/Supabase pooled URL.
DATABASE_URL="postgresql://vpn:vpn_dev@localhost:5432/vpn_dev?schema=public"

# ───── NextAuth ─────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET=""             # NextAuth v5 also reads AUTH_SECRET
AUTH_TRUST_HOST="true"     # required when not on Vercel

# ───── OAuth providers ─────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ───── VPNResellers API (Step 2) ─────
# Get key from https://app.vpnresellers.com/api-access
VPNRESELLERS_API_URL="https://api.vpnresellers.com/v3_1"
VPNRESELLERS_API_KEY=""

# ───── Stripe (Step 4 — feature-flag gated) ─────
STRIPE_ENABLED="false"
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""
STRIPE_PRICE_LIFETIME=""

# ───── Resend (Step 8 — optional in dev, console transport fallback) ─────
RESEND_API_KEY=""
EMAIL_FROM="VPN Service <noreply@example.com>"
EMAIL_ADMIN="admin@example.com"

# ───── Upstash Redis (Step 5 ratelimit + cache) ─────
# Local dev: leave blank to use the docker Redis at REDIS_URL.
# Prod: use Upstash REST endpoint.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REDIS_URL="redis://localhost:6379"

# ───── Encryption ─────
# 32-byte hex key for encrypting VPN passwords at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ───── Feature flags ─────
NEXT_PUBLIC_APP_NAME="VPN Service"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
